{
  "name": "nxtcron",
  "description": "Lightweight, zero-dependency toolkit for building, parsing, validating, scheduling and calculating cron expressions.",
  "license": "MIT",
  "version": "1.0.0",
  "author": {
    "name": "Paul Köhler (komed3)",
    "email": "webmaster@komed3.de",
    "url": "https://komed3.de"
  },
  "homepage": "https://komed3.github.io/nxtcron",
  "keywords": [
    "cron",
    "crontab",
    "cronjob",
    "cron-job",
    "cron-expression",
    "cron-parser",
    "cron-builder",
    "cron-validator",
    "cron-scheduler",
    "schedule",
    "scheduler",
    "parser",
    "builder",
    "typescript",
    "javascript",
    "node",
    "browser"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/komed3/nxtcron.git"
  },
  "bugs": {
    "url": "https://github.com/komed3/nxtcron/issues"
  },
  "funding": {
    "type": "ko-fi",
    "url": "https://ko-fi.com/komed3"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "types": "./dist/types/index.d.ts",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "default": "./dist/esm/index.js",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    },
    "./bundle": "./dist/nxtcron.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:dts": "tsc -p tsconfig.dts.json",
    "build:all": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json && tsc -p tsconfig.dts.json",
    "format": "prettier --ignore-path \"\" --write \"./dist/**/*.@(js|d.ts)\" --log-level warn",
    "bundle": "esbuild dist/esm/index.js --bundle --minify --legal-comments=none --format=iife --global-name=nxtcron --outfile=dist/nxtcron.js",
    "build": "npm run clean && npm run build:all && npm run format && npm run bundle",
    "postbuild": "tsc-alias",
    "prepublishOnly": "npm run build",
    "docs": "typedoc --logLevel Verbose --options typedoc.json"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.17",
    "typedoc": "^0.28.19",
    "typedoc-github-theme": "^0.4.0",
    "typedoc-plugin-missing-exports": "^4.1.3",
    "typescript": "^6.0.3"
  }
}
